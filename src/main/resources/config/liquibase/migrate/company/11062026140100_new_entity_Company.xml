<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">

  <changeSet id="0f2a6b4f-7831-45b7-a10c-ebccc44b5701" author="heltonOliveira">
    <createTable tableName="com_companies">
      <column name="id" type="bigint" autoIncrement="true">
        <constraints primaryKey="true" unique="true" nullable="false"/>
      </column>

      <column name="name" type="text">
        <constraints nullable="false"/>
      </column>

      <column name="email" type="text">
        <constraints nullable="false"/>
      </column>

      <column name="phone" type="text">
        <constraints nullable="false"/>
      </column>

      <column name="image" type="text">
        <constraints nullable="false"/>
      </column>

      <column name="street" type="text">
        <constraints nullable="false"/>
      </column>

      <column name="number" type="numeric">
        <constraints nullable="false"/>
      </column>

      <column name="city" type="text">
        <constraints nullable="false"/>
      </column>

      <column name="neighborhood" type="text">
        <constraints nullable="false"/>
      </column>

      <column name="uf" type="text">
        <constraints nullable="false"/>
      </column>

    </createTable>

    <createIndex tableName="com_companies" indexName="idx_com_companies__id">
      <column name="id" type="bigint"/>
    </createIndex>

    <createIndex tableName="com_companies" indexName="idx_com_companies__name">
      <column name="name" type="text"/>
    </createIndex>

    <createIndex tableName="com_companies" indexName="idx_com_companies__email">
      <column name="email" type="text"/>
    </createIndex>

    <createIndex tableName="com_companies" indexName="idx_com_companies__city">
      <column name="city" type="text"/>
    </createIndex>

    <createIndex tableName="com_companies" indexName="idx_com_companies__uf">
      <column name="uf" type="text"/>
    </createIndex>

  </changeSet>

</databaseChangeLog>
