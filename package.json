{
  "name": "webapp",
  "version": "0.0.0",
  "scripts": {
    "clean": "rm -rf dist && rm -rf build/resources/main/static",
    "build:dev": "npm run clean && ng build webapp --configuration development",
    "build:prod": "npm run clean && ng build webapp --configuration production",
    "build": "yarn run build:prod",
    "merge:i18n": "node merge-i18n.js",
    "ng:cache:clean": "ng cache clean",
    "webapp:dev": "npx ng cache clean && npx ng serve webapp --poll=2000",
    "webapp:prod": "node dist/server/server.mjs",
    "start": "yarn run webapp:dev",
    "watch": "node_modules/.bin/ng build webapp --watch --configuration development",
    "test": "node_modules/.bin/ng test"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^18.0.0",
    "@angular/common": "^18.0.0",
    "@angular/compiler": "^18.0.0",
    "@angular/core": "^18.0.0",
    "@angular/forms": "^18.0.0",
    "@angular/platform-browser": "^18.0.0",
    "@angular/platform-browser-dynamic": "^18.0.0",
    "@angular/router": "^18.0.0",
    "@fortawesome/angular-fontawesome": "^0.15.0",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@fortawesome/fontawesome-svg-core": "^6.5.2",
    "@fortawesome/free-solid-svg-icons": "^6.5.2",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.14.3"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^18.0.0",
    "@angular/cli": "^18.0.0",
    "@angular/compiler-cli": "^18.0.0",
    "@types/node": "^18.0.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "~5.4.2"
  }
}
